CParticleNodeTemplateExport	$63E735B5
{
	Description = {
		"@eng:Controls what metric the evolver should look at to decide when to spawn a particle.\\nDistance : will spawn a child particle when the parent particle has travelled \'SpawnInterval\' world units\\nTime : will spawn a child particle every \'SpawnInterval\' seconds\\nCustom : will read the <float> value of the parent particle\'s \'CustomSpawnMetricField\' field, each frame, and spawn that number of child particles",
	};
	InputPins = {
		"$9D6F4705",
	};
	OutputPins = {
		"$D84CC345",
	};
	WorkspacePosition = int2(176, 440);
	ExportedName = "SpawnMetric";
	ExportedType = int;
	Type = Input;
	InputType = Property;
	VisibleByDefault = true;
	CategoryName = {
		"@eng:Metric",
	};
	UseDropDown = true;
	HasMin = true;
	HasMax = true;
	UseSlider = true;
	EnumList = {
		"Distance",
		"Time",
		"Custom",
	};
	DefaultValueF4 = float4(1.0000000e-01, 0.0000000e+00, 0.0000000e+00, 0.0000000e+00);
	MaxValueF4 = float4(5.0000000e-01, 0.0000000e+00, 0.0000000e+00, 0.0000000e+00);
