CParticleNodeTemplateExport	$C21F30EC
{
	Description = {
		"@eng:Time offset in the [0,1] range that controls when the child particles are spawned. A value of 0 will make the evolver spawn a child particle right when the source particle is born. A value of 1 will offset it forward in time to the next child spawn.\\nIf set to 0, the first particle is spawned at t=0, and the last at t=duration - duration/spawnCount.\\nIf set to 1, the first particle is spawned at t=duration/spawnCount, and the last at t=duration.\\nMore generally, t0 = spawnDelay * duration/spawnCount",
	};
	InputPins = {
		"$5E33AF45",
	};
	OutputPins = {
		"$D522ECB3",
	};
	WorkspacePosition = int2(836, -880);
	ExportedName = "FirstSpawnDelay";
	ExportedType = float;
	Type = Input;
	InputType = Property;
	Order = 5;
	VisibleByDefault = true;
	CategoryName = {
		"@eng:Metric",
	};
	HasMin = true;
	HasMax = true;
	UseSlider = true;
	DefaultValueF4 = float4(5.0000000e-01, 0.0000000e+00, 0.0000000e+00, 0.0000000e+00);
	MaxValueF4 = float4(1.0000000e+00, 0.0000000e+00, 0.0000000e+00, 0.0000000e+00);
}
