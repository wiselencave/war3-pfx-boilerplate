CParticleNodeScript	$1747A386
{
	CustomName = {
		"@eng:Fade on stop",
	};
	ExecStage = Evolve;
	InputPins = {
		"$0D3BA5C1",
		"$9D616718",
	};
	OutputPins = {
		"$8B1A07BB",
	};
	WorkspacePosition = int2(-220, 220);
	Expression = "bool	isStopped = !effect.isRunning();
float	fadeOut = 1 - LifeRatioSinceStop;
float 	lrStep = scene.dt / DeathDelay;
LifeRatioSinceStop = saturate(LifeRatioSinceStop + select(0, lrStep, isStopped));
self.kill(LifeRatioSinceStop == 1);
";
}
