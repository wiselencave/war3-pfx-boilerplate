CParticleNodeAnnotation	$A1D9C4CA
{
	CustomName = {
		"@eng:Small-point Anti-aliasing",
	};
	Description = {
		"@eng:This template computes the onscreen projected size of the particle, and changes the size so the particle never becomes smaller than a given size in pixels, changing the color along the way to preserve perceived luminance.\\nThis effectively produces an \"antialiasing\" effect.\\n\\nIt is useful for small sparks and far away sparks, especially in VR.\\n",
	};
	WorkspacePosition = int2(-396, -792);
	SelfSize = int2(902, 462);
}
