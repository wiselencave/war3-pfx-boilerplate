CParticleNodeTemplateExport	$57E0CE9B
{
	Description = {
		"@eng:Divider for the cursor value.\\nIf set to \'2\', the curve will be sampled at \'t=0.5\' when the cursor reaches \'1.0\', and will be sampled at \'t=1.0\' when the cursor reaches \'2.0\'\\nUseful as a \"time normalizer\". If the cursor mode is set to \'Age\', and the particle life is 1.5 seconds, setting this value to \'1.5\' will stretch the sampling of the curve so that the entire curve gets sampled over the particle lifetime.\\n",
	};
