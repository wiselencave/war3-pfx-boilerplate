	OutputPins = {
		"$1E5C8DCF",
		"$654D151C",
	};
	WorkspacePosition = int2(88, -132);
	Expression = "const int 	kUseLifeRatio = 0;
const int	kUseAge = 1;
const int	kUseEffectAgeSP = 2;
const int	kUseCustom = 3;
const int	kUseEffectAgeEV = 4;

Value = select(select(select(select(Custom,
				EffectAgeEV, Selector == kUseEffectAgeEV),
				EffectAgeSP, Selector == kUseEffectAgeSP),
				Age, Selector == kUseAge),
				LifeRatio, Selector == kUseLifeRatio);

Is01 = (Selector == kUseLifeRatio);";
}
