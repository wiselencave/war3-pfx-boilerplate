CParticleNodeScript	$C01E62BC
{
	InputPins = {
		"$9D2B1A2F",
		"$55289D1E",
		"$EC84D339",
		"$2BBAE5F0",
		"$14978373",
	};
	OutputPins = {
		"$89E0DDB2",
		"$AF0F155D",
		"$DBE780E4",
	};
	WorkspacePosition = int2(0, -110);
	Expression = "float	dist = max(0.1, view.distance(Position));
float	largestResol = max(view.resolution().x, view.resolution().y);
float	curPerceivedSize = dist / (Size * largestResol);
float	scale = select(1, max(MinSize * curPerceivedSize, 1), isfinite(dist)); // view.distance() returns +inf when no views are registered
Size *= scale;
float	colorScale = pow(scale,2);
Color /= select(colorScale.xxxx, colorScale.xxx1, IdentityAlpha);
";
}
