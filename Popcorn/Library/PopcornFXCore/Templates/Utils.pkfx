CParticleNodeAnnotation	$093EF2CC
{
	Description = {
		"@eng:\\n\\n\\n\\n\\n\\nForce repeat <b>OFF</b> if the sampling cursor is in the [0,1] range. This is an optimization applied by the nodegraph compiler, but it\'ll remove the \'frac\' only when the range of the input excludes the 1.0: [0,1[\\n\\nNot doing this causes curves sampled with self.lifeRatio and repeat activated to <b>sample back the origin of the curve when the particle dies</b>, as the lifeRatio will be exactly 1.0, <b>and \'frac\' will return \'0.0\'</b>.\\n\\nThis causes issues when triggering OnDeath events with payloads computed using this template.",
	};
	WorkspacePosition = int2(-550, 374);
	Color = float4(6.0392159e-01, 4.7843140e-01, 8.0784321e-01, 1.0000000e+00);
	SelfSize = int2(946, 880);
}
