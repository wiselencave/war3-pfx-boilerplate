CParticleNodeScript	$B014C0B6
{
	CustomName = {
		"@eng:Integration",
	};
	InputPins = {
		"$ECAFB728",
		"$0ECCB052",
		"$92A2F3BA",
		"$09FA93B0",
		"$676E6F96",
		"$D4A7787E",
	};
	OutputPins = {
		"$4BD453DB",
		"$1E3EA607",
	};
	WorkspacePosition = int2(1980, 44);
	Expression = "// The analytic solution of the 1st order equation: dv/dt = -k*(v-wind) + acc 
// is: v(t0+t) = (v0-wind-acc/k)*exp(-k(t-t0)) + acc/k + wind
// ->: v(   t) = exp(-k*t)*v0 + (1-exp(-k*t))/k*acc + (1-exp(-k*t))*wind

// When k tends towards 0, this equation still admits a solution: v(t) = acc*t
// But numeric issues appear in this case.
// To ensure continuity, we express some critical terms with a taylor expansion / limited development.

bool	selector = k >= 0.1;
float	kdt = k * dt;
float	expkdt = select(1 + kdt * (-1 + kdt / 2),
						accurate.exp(-kdt),
						selector);

float	expfact_o1 = select(dt + kdt/2 * (-dt + dt * kdt / 3),
							(1.f - expkdt) / k,
							selector);

float	expfact_o2 = select(-dt / 2 * (-dt + dt * kdt / 3),
							(-expfact_o1 + dt) / k,
							selector);

pos = pos + vel * expfact_o1 + acc * expfact_o2 + wind * expfact_o2 * k;

vel = vel * expkdt + acc * expfact_o1 + wind * (1 - expkdt);";
}
