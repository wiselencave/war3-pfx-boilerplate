CParticleNodeTemplateExport	$DF717FAE
{
	Description = {
		"@eng:Specifies the radius of the collision object attached to the particle.\\n\\nZero is the fastest, and performs a <b>simple raycast</b> query.\\nNon-zero treats the particle as a sphere, and perform a <b>sphere-sweep</b> query.\\n\\nOnly supported with \'Collide With\' is set to \'Scene\'.\\n\\n<font color=#FA8><b>IMPORTANT:</b> The PopcornFX editor does not yet implement nonzero sweeps, so even if the radius is nonzero, the editor will still do a simple raycast.</font>\\n",
	};
	ExecStage = Evolve;
	InputPins = {
		"$A42AD1C7",
	};
	OutputPins = {
		"$B6786096",
	};
	WorkspacePosition = int2(-880, -660);
	ExportedName = "SweepRadius";
	ExportedType = float;
	Type = Input;
	Order = 8;
	CategoryName = {
		"@eng:Collision",
	};
	HasMin = true;
	PinRules = Rule1;
	BaseVisibility = Hidden;
	RuleResult = Visible;
	DependentProperty = "CollideWith";
	RuleFunction = NotEqual;
	RuleValue = "1";
}
CParticleNodePinIn	$A42AD1C7
{
	SelfName = "DefaultValue";
	Owner = "$DF717FAE";
}
CParticleNodePinOut	$B6786096
{
	SelfName = "Value";
	Owner = "$DF717FAE";
	ConnectedPins = {
		"$1ACB2F29",
	};
}
CParticleNodeTemplateExport	$297DA011
{
	Description = {
		"@eng:If nonzero, treat the particle as a sphere, and perform a sphere-sweep instead of a raycast.\\nSpecifies the radius of the sphere-sweep.",
	};
	ExecStage = Evolve;
	InputPins = {
		"$A382C7A8",
	};
	OutputPins = {
