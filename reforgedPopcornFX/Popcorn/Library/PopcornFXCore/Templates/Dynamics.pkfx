CParticleNodeScript	$724C59D1
{
	CustomName = {
		"@eng:Intersect",
	};
	ExecStage = Evolve;
	InputPins = {
		"$46B97FCF",
		"$0360A6EF",
		"$62505C75",
		"$A04849DC",
		"$1B52C8DE",
		"$F46089F9",
		"$02C5E6A5",
	};
	OutputPins = {
		"$EC3A87CC",
	};
	WorkspacePosition = int2(0, -198);
	Expression = "// Cast a ray in the scene or on a shape
bool	collideWithShape = CollideWith != 0; // CollideWith: 0 = Scene, 1 = Shape
float4	isec = select(	scene.intersect(PrevPosition, RayDir, RayLength, Mask, CollisionFilter),
						Shape.intersect(PrevPosition, RayDir, RayLength),
						collideWithShape);
RawISecResult = isec;";
}
