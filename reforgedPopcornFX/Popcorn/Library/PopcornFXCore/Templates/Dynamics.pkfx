CParticleNodeScript	$099D1270
{
	CustomName = {
		"@eng:Compute ISEC results",
	};
	ExecStage = Evolve;
	InputPins = {
		"$BC56E9F3",
		"$97C90632",
		"$700E27DD",
		"$12F2C564",
		"$6A4FC665",
	};
	OutputPins = {
		"$A056028C",
		"$FB0C32C9",
		"$696EF4C0",
		"$4BD25283",
	};
	WorkspacePosition = int2(528, -286);
	Expression = "// Compute final intersection properties
CollisionPosition = PrevPosition + RayDir * RawISecResult.w;
CollisionNormal = safe_normalize(RawISecResult.xyz);
HasCollided = isfinite(RawISecResult.w) && Mask;
float	collisionDistance = select(infinity, RawISecResult.w, Mask);
HitFrac = select(1, collisionDistance / RayLength, HasCollided);

debug.assert(HitFrac >= 0 && HitFrac <= 1);
";
}
