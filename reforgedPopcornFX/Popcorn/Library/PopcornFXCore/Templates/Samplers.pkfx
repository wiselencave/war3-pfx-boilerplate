CParticleNodeScript	$2951A2B6
{
	InputPins = {
		"$1C94830D",
		"$4EA54A8F",
		"$48A5FC1F",
		"$36E68817",
		"$BE966041",
	};
	OutputPins = {
		"$971B2D93",
	};
	WorkspacePosition = int2(44, -66);
	Expression = "int	filterMap = iif(FilterMap == 0, spectrumFilter.Point,
				iif(FilterMap == 1, spectrumFilter.Linear,
									spectrumFilter.Cubic));
int	filterMip = iif(FilterMip == 0, spectrumFilter.Point,
				iif(FilterMip == 1, spectrumFilter.Linear,
									spectrumFilter.Cubic));

Value = 0 + iif(ConvolutionLevel == 0,
			Sampler.sample(Cursor, filterMap),
			Sampler.sample(Cursor, ConvolutionLevel, filterMap, filterMip));
";
}
