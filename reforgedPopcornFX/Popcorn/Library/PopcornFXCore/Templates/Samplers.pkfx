CParticleNodeTemplateExport	$2BA66620
{
	Description = {
		"@eng:Filter mode telling how the sample function will weight the nearby spectrum values\\n - Point : will return the closest value. Fastest, high aliasing\\n - Linear : will interpolate between the two nearby values\\n - Cubic : will smoothly interpolate between the 4 nearby values. Slowest, best quality, smooth curve",
	};
	InputPins = {
		"$CE1FA446",
	};
	OutputPins = {
		"$791F5A77",
	};
	WorkspacePosition = int2(-308, 154);
	ExportedName = "Filter";
	ExportedType = int;
	Type = Input;
	InputType = Property;
	Order = 10;
	VisibleByDefault = true;
	CategoryName = {
		"@eng:Filtering",
	};
	UseDropDown = true;
	EnumList = {
		"Point",
		"Linear",
		"Cubic",
	};
}
